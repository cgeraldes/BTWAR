fit_arima <- auto.arima(dados$treino)

# Treino
arima_fitted_tr <- fitted(fit_arima)

# Teste
fc_arima <- forecast(fit_arima, h = length(dados$teste))
arima_pred_te <- as.numeric(fc_arima$mean)
plot_comparison_gg <- function(res,
                               arima_tr,
                               arima_te,
                               dataset = c("train", "test"),
                               fs){

  dataset <- match.arg(dataset)

  if(dataset == "train"){
    y_real <- res$train$y_real
    y_btwar <- res$train$yhat

    # alinhar ARIMA com BTWAR (remover primeiros p valores)
    p <- length(res$parameters$phi)
    arima_vals <- arima_tr[(p+1):length(arima_tr)]
  } else {
    y_real <- res$test$y_real
    y_btwar <- res$test$yhat
    arima_vals <- arima_te
  }

  n <- length(y_real)
  time <- (0:(n - 1)) / fs

  df <- data.frame(
    time   = time,
    True   = y_real,
    BTWAR  = y_btwar,
    ARIMA  = arima_vals
  )

  df_long <- df |>
    tidyr::pivot_longer(
      cols = -time,
      names_to = "Series",
      values_to = "Value"
    )

  ggplot2::ggplot(df_long,
                  ggplot2::aes(x = time,
                               y = Value,
                               color = Series,
                               linewidth = Series)) +
    ggplot2::geom_line(alpha = 0.9) +
    ggplot2::scale_color_manual(
      values = c(
        "True"  = "black",
        "BTWAR" = "blue",
        "ARIMA" = "red"
      )
    ) +
    ggplot2::scale_linewidth_manual(
      values = c(
        "True"  = 2,
        "BTWAR" = 1.2,
        "ARIMA" = 1.2
      )
    ) +
    ggplot2::theme_minimal() +
    ggplot2::theme(
      legend.position = "top",
      legend.title = ggplot2::element_blank()
    )
}
plot_comparison_gg(
  res,
  arima_tr = arima_fitted_tr,
  arima_te = arima_pred_te,
  dataset = "train",
  fs = fs
)

plot_comparison_gg(
  res,
  arima_tr = arima_fitted_tr,
  arima_te = arima_pred_te,
  dataset = "test",
  fs = fs
)
