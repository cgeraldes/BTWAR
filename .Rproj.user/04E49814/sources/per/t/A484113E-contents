id <- 119
window_sec = 600
fs = 2
dados <- ecg_ARn(subject = id, window_sec = window_sec, fs = fs)

res <- run_btwar_analysis(
  y_tr_raw = dados$treino,
  y_te_raw = dados$teste,
  fs = 2,
  method = "ls"
)

