plot_btwar_predictions_gg <- function(
    res,
    dataset = c("train", "test"),
    fs,
    title = NULL
) {

  library(ggplot2)
  library(tidyr)
  library(dplyr)

  dataset <- match.arg(dataset)

  if (dataset == "train") {
    y_real <- res$train$y_real
    yhat   <- res$train$yhat
  } else {
    y_real <- res$test$y_real
    yhat   <- res$test$yhat
  }

  n <- length(y_real)
  time <- (0:(n - 1)) / fs

  if (is.null(title)) {
    title <- paste("BTWAR prediction (", dataset, ")", sep = "")
  }

  df <- data.frame(
    time = time,
    `True signal` = y_real,
    `BTWAR prediction` = yhat,
    check.names = FALSE
  )

  df_long <- df %>%
    pivot_longer(
      cols = -time,
      names_to = "Series",
      values_to = "Value"
    ) %>%
    filter(!is.na(Value))

  df_long$Series <- factor(
    df_long$Series,
    levels = c(
      "True signal",
      "BTWAR prediction"
    )
  )

  ggplot(
    df_long,
    aes(
      x = time,
      y = Value,
      color = Series,
      linewidth = Series
    )
  ) +
    geom_line(alpha = 0.9) +

    scale_color_manual(
      values = c(
        "True signal" = "goldenrod",
        "BTWAR prediction" = "blue"
      )
    ) +

    scale_linewidth_manual(
      values = c(
        "True signal" = 2.0,
        "BTWAR prediction" = 1.2
      )
    ) +

    labs(
      title = title,
      x = "Time (s)",
      y = "Amplitude"
    ) +

    theme_minimal(base_size = 11) +
    theme(
      legend.position = "top",
      legend.title = element_blank()
    )
}

plot_btwar_predictions_gg(
  res,
  dataset = "train",
  fs = 2
)

plot_btwar_predictions_gg(
  res,
  dataset = "test",
  fs = 2
)
