get_rr_AR <- function(
    subject = 1,
    fs = 4,               # define a interpolação
    window_sec = 300,     # 5 minutos
    start = NULL,        # início em segundos (NULL = aleatório)
    out_csv = "rr_series.csv"
){
  library(httr)
  library(stringr)
  library(zoo)
  set.seed(123)
  base_url <- "https://physionet.org/files/rr-interval-healthy-subjects/1.0.0/"

  # download & leitura (igual antes)
  #page <- content(GET(base_url), "text")
  #files <- stringr::str_extract_all(page, "[A-Za-z0-9_-]+\\.txt")[[1]]
  library(rvest)
  library(magrittr)

  page <- read_html(base_url)

  files <- page %>%
    html_nodes("a") %>%
    html_attr("href") %>%
    grep("^\\d+\\.txt$", ., value = TRUE) %>%
    sort()

  file_name <- files[subject]

  if(!file.exists(file_name)){
    download.file(paste0(base_url,file_name), file_name, mode="wb")
  }

  rr <- read.table(file_name, header=FALSE)
  colnames(rr) <- "interval_ms"

  rr$interval_s <- rr$interval_ms/1000
  rr$time <- cumsum(rr$interval_s)

  # -----------------------------
  # Escolher janela
  # -----------------------------
  Tmax <- max(rr$time)
  if(is.null(start)) start <- runif(1, 0, Tmax-window_sec)
  end <- start + window_sec

  rr <- rr[rr$time >= start & rr$time <= end, ]

  # -----------------------------
  # Reamostrar
  # -----------------------------
  t_uniform <- seq(start, end, by=1/fs)
  rr_interp <- na.approx(zoo(rr$interval_s, rr$time),
                         xout=t_uniform, rule=2)

  rr_ts <- as.numeric(rr_interp)
  t_uniform <- t_uniform[1:length(rr_ts)]

  rr_df <- data.frame(time=t_uniform, rr=rr_ts)
  write.csv(rr_df, out_csv, row.names=FALSE)

  return(rr_df)
}

ecg_ARn <- function(subject = 1,
                    fs = 4,
                    burn = 0,
                    window_sec = 300,
                    split = 0.8) {
  set.seed(123)
  rr <- get_rr_AR(subject = subject, fs = fs, window_sec = window_sec)

  x <- rr$rr
  x <- x[!is.na(x)]

  out <- make_stationary(x)
  d = out$d
  p_value = out$p_value
  x <- out$x_stationary


  if (burn > 0) x <- x[(burn+1):length(x)]

  n_tot   <- length(x)
  n_train <- floor(split * n_tot)

  list(
    treino = x[1:n_train],
    teste  = x[(n_train+1):n_tot],
    d = d,
    p_value = p_value
  )
}
