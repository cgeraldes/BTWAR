plot_btwar_predictions_gg <- function(res, dataset = "train", fs){
if(dataset == "train"){
y_real <- res$train$y_real
yhat   <- res$train$yhat
} else {
y_real <- res$test$y_real
yhat   <- res$test$yhat
}
n <- length(y_real)
time <- (0:(n - 1)) / fs
df <- data.frame(
time = time,
True = y_real,
BTWAR = yhat
)
df_long <- df |>
pivot_longer(cols = -time,
names_to = "Series",
values_to = "Value")
ggplot(df_long,
aes(x = time,
y = Value,
color = Series,
linewidth = Series)) +
geom_line(alpha = 0.9) +
scale_color_manual(values = c("True" = "goldenrod",
"BTWAR" = "blue")) +
scale_linewidth_manual(values = c("True" = 2,
"BTWAR" = 1.2)) +
theme_minimal() +
theme(legend.position = "top",
legend.title = element_blank())
}
plot_btwar_predictions_gg(res, "train", fs)
plot_btwar_predictions_gg(res, "test", fs)
##################
##################
##################
fit_arima <- auto.arima(dados$treino)
# Treino
arima_fitted_tr <- fitted(fit_arima)
# Teste
fc_arima <- forecast(fit_arima, h = length(dados$teste))
arima_pred_te <- as.numeric(fc_arima$mean)
plot_comparison_gg <- function(res,
arima_tr,
arima_te,
dataset = c("train", "test"),
fs){
dataset <- match.arg(dataset)
if(dataset == "train"){
y_real <- res$train$y_real
y_btwar <- res$train$yhat
# alinhar ARIMA com BTWAR (remover primeiros p valores)
p <- length(res$parameters$phi)
arima_vals <- arima_tr[(p+1):length(arima_tr)]
} else {
y_real <- res$test$y_real
y_btwar <- res$test$yhat
arima_vals <- arima_te
}
n <- length(y_real)
time <- (0:(n - 1)) / fs
df <- data.frame(
time   = time,
True   = y_real,
BTWAR  = y_btwar,
ARIMA  = arima_vals
)
df_long <- df |>
tidyr::pivot_longer(
cols = -time,
names_to = "Series",
values_to = "Value"
)
ggplot2::ggplot(df_long,
ggplot2::aes(x = time,
y = Value,
color = Series,
linewidth = Series)) +
ggplot2::geom_line(alpha = 0.9) +
ggplot2::scale_color_manual(
values = c(
"True"  = "black",
"BTWAR" = "blue",
"ARIMA" = "red"
)
) +
ggplot2::scale_linewidth_manual(
values = c(
"True"  = 2,
"BTWAR" = 1.2,
"ARIMA" = 1.2
)
) +
ggplot2::theme_minimal() +
ggplot2::theme(
legend.position = "top",
legend.title = ggplot2::element_blank()
)
}
plot_comparison_gg(
res,
arima_tr = arima_fitted_tr,
arima_te = arima_pred_te,
dataset = "train",
fs = fs
)
plot_comparison_gg(
res,
arima_tr = arima_fitted_tr,
arima_te = arima_pred_te,
dataset = "test",
fs = fs
)
#' dataset suitable for autoregressive modeling.
#'
#' @param series Numeric time series.
#' @param p AR order.
#' @param train_frac Training fraction (0-1).
#' @param scale Logical; whether to standardize series.
#'
#' @return List containing training/test splits and scaling info.
#'
#' @export
make_AR_dataset <- function(
series,
p = 5,
train_frac = 0.7,
scale = TRUE
){
stopifnot(is.numeric(series))
stopifnot(p >= 1)
n <- length(series)
if(scale){
mu <- mean(series, na.rm = TRUE)
sdv <- stats::sd(series, na.rm = TRUE)
s <- (series - mu) / sdv
} else {
mu <- 0
sdv <- 1
s <- series
}
X <- stats::embed(s, p + 1)[, -1]
y <- stats::embed(s, p + 1)[, 1]
N <- nrow(X)
train_N <- floor(train_frac * N)
X_train <- X[seq_len(train_N), , drop = FALSE]
y_train <- y[seq_len(train_N)]
X_test  <- X[(train_N + 1):N, , drop = FALSE]
y_test  <- y[(train_N + 1):N]
list(
treino  = X_train,
y_train = y_train,
X_test  = X_test,
y_test  = y_test,
mean    = mu,
sd      = sdv
)
}
