rr   = as.numeric(rr_interp)
)
}
############################################################
# 2. Create train/test split
############################################################
ecg_ARn <- function(subject = 1, fs = 2, window_sec = 600, split = 0.7){
rr <- get_rr_AR(subject = subject, fs = fs, window_sec = window_sec)
x <- as.numeric(rr$rr)
x <- x[!is.na(x)]
n_tot   <- length(x)
n_train <- floor(split * n_tot)
list(
treino = x[1:n_train],
teste  = x[(n_train + 1):n_tot]
)
}
############################################################
# 3. Run BTWAR
############################################################
id <- 10   # valid subject index
fs <- 2
dados <- ecg_ARn(subject = id, fs = fs)
res <- BTWAR::btwar_fit(
y_tr_raw = dados$treino,
y_te_raw = dados$teste,
fs = fs,
method = "ls",
N_vec = 2:4
)
cat("\nBTWAR Performance:\n")
print(res$performance)
############################################################
# 4. Compare with ARIMA (true out-of-sample forecast)
############################################################
# Fit on training (centered)
fit_arima <- forecast::Arima(
res$train$y_real,
order = c(5, 0, 0)
)
# Training fitted values (aligned length)
arima_fitted_tr <- tail(as.numeric(fitted(fit_arima)), length(res$train$yhat))
arima_vals_te <- tail(
as.numeric(fitted(forecast::Arima(dados$teste - res$mu, model = fit_arima))),
length(res$test$yhat)
)
# RMSE comparison
rmse_arima_te <- sqrt(mean((res$test$y_real - arima_vals_te)^2))
cat("\nRMSE Comparison:\n")
cat("BTWAR Test RMSE :", res$performance$rmse_test, "\n")
cat("ARIMA Test RMSE :", rmse_arima_te, "\n")
# Fit on training (centered)
fit_arima <- forecast::Arima(
res$train$y_real,
order = c(2, 0, 0)
)
# Training fitted values (aligned length)
arima_fitted_tr <- tail(as.numeric(fitted(fit_arima)), length(res$train$yhat))
arima_vals_te <- tail(
as.numeric(fitted(forecast::Arima(dados$teste - res$mu, model = fit_arima))),
length(res$test$yhat)
)
# RMSE comparison
rmse_arima_te <- sqrt(mean((res$test$y_real - arima_vals_te)^2))
cat("\nRMSE Comparison:\n")
cat("BTWAR Test RMSE :", res$performance$rmse_test, "\n")
cat("ARIMA Test RMSE :", rmse_arima_te, "\n")
plot(res, dataset = "train", fs = fs,
colour_observed = "goldenrod",
colour_btwar = "blue",
lwd_observed = 2,
lwd_btwar = 1.2)
plot(res, dataset = "test", fs = fs,
colour_observed = "goldenrod",
colour_btwar = "blue",
lwd_observed = 2,
lwd_btwar = 1.2)
plot(res, dataset = "train", fs = fs,
colour_observed = "goldenrod",
colour_btwar = "blue",
colour_external = "red",
lwd_observed = 2,
lwd_btwar = 1.2,
lwd_external = 1.2,
external      = arima_fitted_tr,
external_name = "ARIMA",
layer_order   = c("Observed", "BTWAR", "ARIMA"))
plot(res, dataset = "test", fs = fs,
colour_observed = "goldenrod",
colour_btwar = "blue",
colour_external = "red",
lwd_observed = 2,
lwd_btwar = 1.2,
lwd_external = 1.2,
external      = arima_vals_te,
external_name = "ARIMA",
layer_order   = c("BTWAR", "Observed", "ARIMA"))
############################################################
# BTWAR – End-to-End Test Script (Revised)
############################################################
rm(list = ls())
library(BTWAR)
library(rvest)
library(zoo)
library(forecast)
set.seed(123)
############################################################
# 1. Download and prepare RR interval data
############################################################
get_rr_AR <- function(
subject = 1,
fs = 2,
window_sec = 600,
start = NULL
){
base_url <- "https://physionet.org/files/rr-interval-healthy-subjects/1.0.0/"
page <- read_html(base_url)
files <- page |>
html_nodes("a") |>
html_attr("href") |>
grep("^\\d+\\.txt$", x = _, value = TRUE) |>
sort()
if(subject > length(files))
stop("Invalid subject index.")
file_name <- files[subject]
if(!file.exists(file_name)){
download.file(paste0(base_url, file_name), file_name, mode="wb")
}
rr <- read.table(file_name, header = FALSE)
colnames(rr) <- "interval_ms"
rr$interval_s <- rr$interval_ms / 1000
rr$time <- cumsum(rr$interval_s)
Tmax <- max(rr$time)
if(Tmax <= window_sec)
stop("Window larger than available signal.")
if(is.null(start))
start <- runif(1, 0, Tmax - window_sec)
end <- start + window_sec
rr <- rr[rr$time >= start & rr$time <= end, ]
t_uniform <- seq(start, end, by = 1/fs)
rr_interp <- zoo::na.approx(
zoo::zoo(rr$interval_s, rr$time),
xout = t_uniform,
rule = 2
)
data.frame(
time = t_uniform[1:length(rr_interp)],
rr   = as.numeric(rr_interp)
)
}
############################################################
# 2. Create train/test split
############################################################
ecg_ARn <- function(subject = 1, fs = 2, window_sec = 600, split = 0.7){
rr <- get_rr_AR(subject = subject, fs = fs, window_sec = window_sec)
x <- as.numeric(rr$rr)
x <- x[!is.na(x)]
n_tot   <- length(x)
n_train <- floor(split * n_tot)
list(
treino = x[1:n_train],
teste  = x[(n_train + 1):n_tot]
)
}
############################################################
# 3. Run BTWAR
############################################################
id <- 10   # valid subject index
fs <- 2
dados <- ecg_ARn(subject = id, fs = fs)
res <- BTWAR::btwar_fit(
y_tr_raw = dados$treino,
y_te_raw = dados$teste,
fs = fs,
method = "ls",
N_vec = 2:4
)
cat("\nBTWAR Performance:\n")
print(res$performance)
############################################################
# 4. Compare with ARIMA (one-step-ahead, same scale as BTWAR)
############################################################
# Fit ARIMA on centered training series
fit_arima <- forecast::Arima(
res$train$y_real,
order = c(2, 0, 0)
)
# Training: one-step-ahead fitted values (aligned with BTWAR window)
arima_fitted_tr <- tail(as.numeric(fitted(fit_arima)), length(res$train$yhat))
# Test: one-step-ahead fitted values using training model (aligned with BTWAR window)
arima_vals_te <- tail(
as.numeric(fitted(forecast::Arima(dados$teste - res$mu, model = fit_arima))),
length(res$test$yhat)
)
# RMSE comparison (both evaluated on the same observations)
rmse_arima_te <- sqrt(mean((res$test$y_real - arima_vals_te)^2))
cat("\nRMSE Comparison:\n")
cat("BTWAR Test RMSE :", res$performance$rmse_test, "\n")
cat("ARIMA Test RMSE :", rmse_arima_te, "\n")
# Fit on training (centered)
fit_arima <- forecast::Arima(
res$train$y_real,
order = c(2, 0, 0)
)
# Training fitted values (aligned length)
arima_fitted_tr <- tail(as.numeric(fitted(fit_arima)), length(res$train$yhat))
arima_vals_te <- tail(
as.numeric(fitted(forecast::Arima(dados$teste - res$mu, model = fit_arima))),
length(res$test$yhat)
)
# RMSE comparison
rmse_arima_te <- sqrt(mean((res$test$y_real - arima_vals_te)^2))
cat("\nRMSE Comparison:\n")
cat("BTWAR Test RMSE :", res$performance$rmse_test, "\n")
cat("ARIMA Test RMSE :", rmse_arima_te, "\n")
############################################################
# 5. Plots BTWAR
############################################################
plot(res, dataset = "train", fs = fs,
colour_observed = "goldenrod",
colour_btwar = "blue",
lwd_observed = 2,
lwd_btwar = 1.2)
plot(res, dataset = "test", fs = fs,
colour_observed = "goldenrod",
colour_btwar = "blue",
lwd_observed = 2,
lwd_btwar = 1.2)
############################################################
# 6. Plots BTWAR vs ARIMA
############################################################
# Treino
plot(res, dataset = "train", fs = fs,
colour_observed = "goldenrod",
colour_btwar = "blue",
colour_external = "red",
lwd_observed = 2,
lwd_btwar = 1.2,
lwd_external = 1.2,
external      = arima_fitted_tr,
external_name = "ARIMA",
layer_order   = c("Observed", "BTWAR", "ARIMA"))
plot(res, dataset = "test", fs = fs,
colour_observed = "goldenrod",
colour_btwar = "blue",
colour_external = "red",
lwd_observed = 2,
lwd_btwar = 1.2,
lwd_external = 1.2,
external      = arima_vals_te,
external_name = "ARIMA",
layer_order   = c("BTWAR", "Observed", "ARIMA"))
