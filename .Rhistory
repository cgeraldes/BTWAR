inicio = "2000-01-01",
fim = Sys.Date(),
coluna = "Adjusted",
burn = 0,
split = 0.8,
logret = FALSE,
dif = FALSE) {
library(quantmod)
set.seed(123)
dados <- suppressWarnings(
getSymbols(ticker,
src="yahoo",
from=inicio,
to=fim,
auto.assign=FALSE)
)
if (coluna=="Adjusted")      x <- Ad(dados)
else if (coluna=="Close")    x <- Cl(dados)
else if (coluna=="Open")     x <- Op(dados)
else if (coluna=="High")     x <- Hi(dados)
else if (coluna=="Low")      x <- Lo(dados)
else if (coluna=="Volume")   x <- Vo(dados)
else stop("Coluna inválida")
x <- as.numeric(na.omit(x))
if (logret){
x <- diff(log(x))
x <- na.omit(x)
} else if (dif){
x <- diff(x)
}
if (burn > 0) x <- x[(burn+1):length(x)]
n_tot   <- length(x)
n_train <- floor(split * n_tot)
list(
treino = x[1:n_train],
teste  = x[(n_train+1):n_tot]
)
}
get_rr_AR <- function(
subject = 1,
fs = 4,               # define a interpolação
window_sec = 300,     # 5 minutos
start = NULL,        # início em segundos (NULL = aleatório)
out_csv = "rr_series.csv"
){
library(httr)
library(stringr)
library(zoo)
set.seed(123)
base_url <- "https://physionet.org/files/rr-interval-healthy-subjects/1.0.0/"
# download & leitura (igual antes)
#page <- content(GET(base_url), "text")
#files <- stringr::str_extract_all(page, "[A-Za-z0-9_-]+\\.txt")[[1]]
library(rvest)
library(magrittr)
page <- read_html(base_url)
files <- page %>%
html_nodes("a") %>%
html_attr("href") %>%
grep("^\\d+\\.txt$", ., value = TRUE) %>%
sort()
file_name <- files[subject]
print(file_name)
if(!file.exists(file_name)){
download.file(paste0(base_url,file_name), file_name, mode="wb")
}
rr <- read.table(file_name, header=FALSE)
colnames(rr) <- "interval_ms"
rr$interval_s <- rr$interval_ms/1000
rr$time <- cumsum(rr$interval_s)
# -----------------------------
# Escolher janela
# -----------------------------
Tmax <- max(rr$time)
if(is.null(start)) start <- runif(1, 0, Tmax-window_sec)
end <- start + window_sec
print("cheguei")
rr <- rr[rr$time >= start & rr$time <= end, ]
# -----------------------------
# Reamostrar
# -----------------------------
t_uniform <- seq(start, end, by=1/fs)
rr_interp <- na.approx(zoo(rr$interval_s, rr$time),
xout=t_uniform, rule=2)
rr_ts <- as.numeric(rr_interp)
t_uniform <- t_uniform[1:length(rr_ts)]
rr_df <- data.frame(time=t_uniform, rr=rr_ts)
write.csv(rr_df, out_csv, row.names=FALSE)
return(rr_df)
}
ecg_ARn <- function(subject = 1,
fs = 4,
burn = 0,
window_sec = 300,
split = 0.8) {
set.seed(123)
rr <- get_rr_AR(subject = subject, fs = fs, window_sec = window_sec)
x <- rr$rr
x <- x[!is.na(x)]
out <- make_stationary(x)
d = out$d
p_value = out$p_value
x <- out$x_stationary
if (burn > 0) x <- x[(burn+1):length(x)]
n_tot   <- length(x)
n_train <- floor(split * n_tot)
list(
treino = x[1:n_train],
teste  = x[(n_train+1):n_tot],
d = d,
p_value = p_value
)
}
get_eeg_band_AR <- function(
edf_url = "https://www.physionet.org/files/sleep-edfx/1.0.0/sleep-cassette/SC4001E0-PSG.edf?download",
channel = "Fpz-Cz",
band = c(8,13),
fs_new = 26,      # <<< downsample target
N = 600,         # <<< nº de amostras depois de downsample
start = NULL,
out_csv = "eeg_band.csv"
){
library(httr)
library(edfReader)
library(signal)
# -----------------------------
# Download
# -----------------------------
edf_file <- basename(strsplit(edf_url,"\\?")[[1]][1])
if(!file.exists(edf_file)){
download.file(edf_url, edf_file, mode="wb")
}
# -----------------------------
# Ler EDF
# -----------------------------
#edf <- readEdfSignals(edf_file)
edf <- readEdfHeader(edf_file)
signals <- readEdfSignals(edf_file)
if(!(channel %in% names(edf$signalList$signal))){
stop("Canal inválido")
}
sig <- signals[[channel]]$signal
fs  <- edf$signalHeaders[[channel]]$sRate
# -----------------------------
# Filtro de banda
# -----------------------------
bpf <- butter(4, band/(fs/2), type="pass")
sig_filt <- filtfilt(bpf, sig)
# -----------------------------
# Downsample para fs_new
# -----------------------------
factor <- round(fs / fs_new)
sig_ds <- sig_filt[ seq(1, length(sig_filt), by=factor) ]
fs <- fs / factor
# -----------------------------
# Escolher janela de N amostras
# -----------------------------
T <- length(sig_ds)
if(is.null(start)) start <- sample(1:(T - N), 1)
sig_ds <- sig_ds[start:(start + N - 1)]
# -----------------------------
# Série temporal
# -----------------------------
time <- seq(0, N-1) / fs
eeg_df <- data.frame(time=time, value=sig_ds)
# -----------------------------
# Guardar
# -----------------------------
write.csv(eeg_df, out_csv, row.names=FALSE)
message("EEG banda ", band[1], "-", band[2], " Hz | fs ≈ ", round(fs,2),
" Hz | N = ", N)
return(eeg_df)
}
eeg_ARn <- function(
band = c(8,13),
channel = "Fpz-Cz",
fs_new = 26,
N = 600,
burn = 0,
split = 0.8
){
set.seed(123)
eeg <- get_eeg_band_AR(
band = band,
channel = channel,
fs_new = fs_new,
N = N
)
x <- eeg$value
x <- x[!is.na(x)]
# Burn-in
if (burn > 0) {
if (burn >= length(x)) stop("burn maior que a série")
x <- x[(burn+1):length(x)]
}
n_tot   <- length(x)
n_train <- floor(split * n_tot)
list(
treino = x[1:n_train],
teste  = x[(n_train+1):n_tot]
)
}
make_AR_dataset <- function(
series,           # vetor numérico da série temporal
p = 5,            # ordem do AR
train_frac = 0.7, # fração para treino
scale = TRUE      # normalizar?
){
set.seed(123)
stopifnot(is.numeric(series))
stopifnot(p >= 1)
n <- length(series)
split <- floor(train_frac * n)
# -----------------------------
# 1) Normalização
# -----------------------------
if(scale){
mu <- mean(series, na.rm=TRUE)
sdv <- sd(series, na.rm=TRUE)
s <- (series - mu) / sdv
} else {
mu <- 0; sdv <- 1
s <- series
}
# -----------------------------
# 2) Criar matriz AR(p)
# -----------------------------
X <- embed(s, p+1)[,-1]   # lags
y <- embed(s, p+1)[,1]    # alvo
# -----------------------------
# 3) Ajustar índice treino/teste
# -----------------------------
N <- nrow(X)
train_N <- floor(train_frac * N)
X_train <- X[1:train_N,]
y_train <- y[1:train_N]
X_test  <- X[(train_N+1):N,]
y_test  <- y[(train_N+1):N]
return(list(
treino = X_train,
y_train = y_train,
X_test  = X_test,
y_test  = y_test,
mean = mu,
sd = sdv
))
}
run_subject_analysis <- function(id, fs = 2, window_sec = 600,method) {
library(forecast)
library(tseries)
# =========================================================
# 1. DADOS
# =========================================================
dados <- ecg_ARn(subject = id, window_sec = window_sec, fs = fs)
y_tr_raw <- dados$treino
y_te_raw <- dados$teste
# =========================================================
# 2. ESTACIONARIDADE + CENTRAGEM
# =========================================================
adf_p   <- adf.test(y_tr_raw)$p.value
kpss_p <- kpss.test(y_tr_raw)$p.value
apply_diff <- (adf_p > 0.05) || (kpss_p < 0.05)
if (apply_diff) {
y_tr <- diff(y_tr_raw)
y_te <- diff(y_te_raw)
d_used <- 1
} else {
y_tr <- y_tr_raw
y_te <- y_te_raw
d_used <- 0
}
mu_tr <- mean(y_tr)
y_tr <- y_tr - mu_tr
y_te <- y_te - mu_tr
# =========================================================
# 3. ARIMA (AR puro)
# =========================================================
set.seed(123)
fit_arima <- auto.arima(
y_tr,
d = 0,
max.d = 0,
max.q = 0,
seasonal = FALSE,
stepwise = FALSE,
approximation = FALSE
)
phi_arima <- fit_arima$coef
phi_ar <- phi_arima[grep("^ar", names(phi_arima))]
phi_ma <- phi_arima[grep("^ma", names(phi_arima))]
# =========================================================
# 4. BTW–AR (CV)
# =========================================================
As_vec <- seq(20, 60, by = 5)
N_vec  <- 2:20
cv_res <- cv_butterworth_AsN(
y      = y_tr,
As_vec = As_vec,
N_vec  = N_vec,
fs     = fs,
method = method
)
phi_BTW <- cv_res$all[[cv_res$best_i]]$phi
N_opt <- cv_res$best$N
A_opt <- cv_res$best$A
fc_opt <- cv_res$best$fc
# =========================================================
# 5. PREVISÕES (TREINO)
# =========================================================
t0 <- max(length(phi_BTW), length(phi_arima)) + 1
Tt <- length(y_tr)
y0_BTW_tr <- yhat_ar(y_tr, phi_BTW)[t0:Tt]
yhat_ARIMA_tr <- yhat_arma(y_tr, phi_ar, phi_ma)[t0:Tt]
y_real_tr <- y_tr[t0:Tt]
#alpha_tr <- alpha_opt(y_real_tr, y0_BTW_tr)
alpha_tr <- alpha_estimate(
x      = y_real_tr,
yhat   = y0_BTW_tr,
method = method
)
yhat_BTW_tr <- alpha_tr * y0_BTW_tr
rmse_BTW_tr <- rmse(y_real_tr, yhat_BTW_tr)
rmse_ARIMA_tr <- rmse(y_real_tr, yhat_ARIMA_tr)
e_BTW_tr <- y_real_tr - yhat_BTW_tr
e_ARIMA_tr <- y_real_tr - yhat_ARIMA_tr
dm_tr <- dm.test(e_BTW_tr, e_ARIMA_tr, power = 2)$p.value
# =========================================================
# 6. PREVISÕES (TESTE)
# =========================================================
Tte <- length(y_te)
y0_BTW_te <- yhat_ar(y_te, phi_BTW)[t0:Tte]
yhat_BTW_te <- alpha_tr * y0_BTW_te
yhat_ARIMA_te <- yhat_arma(y_te, phi_ar, phi_ma)[t0:Tte]
y_real_te <- y_te[t0:Tte]
rmse_BTW_te <- rmse(y_real_te, yhat_BTW_te)
rmse_ARIMA_te <- rmse(y_real_te, yhat_ARIMA_te)
e_BTW_te <- y_real_te - yhat_BTW_te
e_ARIMA_te <- y_real_te - yhat_ARIMA_te
dm_te <- dm.test(e_BTW_te, e_ARIMA_te, power = 2)$p.value
wilcox_te <- wilcox.test(e_BTW_te^2, e_ARIMA_te^2, paired = TRUE)$p.value
#######################################
# =========================================================
# 7. OUTPUT (UMA LINHA)
# =========================================================
phi_ar_str <- paste(round(phi_ar, 4), collapse = ", ")
phi_ma_str <- paste(round(phi_ma, 4), collapse = ", ")
return(list(
summary = data.frame(
subject = id,
d_used = d_used,
N_opt = N_opt,
A_opt = A_opt,
fc_opt = fc_opt,
rmse_ARIMA_train = rmse_ARIMA_tr,
rmse_BTW_train = rmse_BTW_tr,
rmse_ARIMA_test = rmse_ARIMA_te,
rmse_BTW_test = rmse_BTW_te,
DM_p_test = dm_te,
Wilcox_p_test = wilcox_te
),
train = list(
y_real = y_real_tr,
yhat_BTW = yhat_BTW_tr,
yhat_ARIMA = yhat_ARIMA_tr
),
test = list(
y_real = y_real_te,
yhat_BTW = yhat_BTW_te,
yhat_ARIMA = yhat_ARIMA_te
)
))
}
run_subject_analysis_safe <- function(id, fs = 2, window_sec = 600, method = "ls") {
tryCatch({
run_subject_analysis(id, fs, window_sec, method)
}, error = function(e) {
message(sprintf("⚠️ Subject %d skipped: %s", id, e$message))
return(NULL)
})
}
subjects <- 119
results_list <- lapply(subjects, run_subject_analysis_safe)
plot_predictions <- function(
y_real,
yhat_BTW,
yhat_ARIMA,
fs,
title = ""
) {
n <- length(y_real)
t <- (0:(n - 1)) / fs   # tempo em segundos
plot(t, y_real, type = "l", lwd = 2, col = "yellow",
xlab = "Time (s)", ylab = "Amplitude",
main = title)
lines(t, yhat_ARIMA, col = "red", lwd = 1.5)
lines(t, yhat_BTW, col = "blue", lwd = 1.5)
legend("topright",
legend = c("Training Real Signal",
"BTW--AR Model prediction",
"ARIMA Model prediction"),
col = c("yellow", "blue", "red"),
lty = c(1, 1, 1),
lwd = c(2, 1.5, 1.5),
bty = "n")
}
# ---- Treino
